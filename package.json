{
  "name": "techbill-prisma",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "npm install --prefix techbill-pos && npm run build --prefix techbill-pos && node -e \"const fs = require('fs'); fs.cpSync('techbill-pos/dist', 'dist', { recursive: true });\"",
    "migrate": "prisma migrate dev",
    "seed": "ts-node prisma/seed.ts",
    "db:reset": "prisma migrate reset --force"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcrypt": "^5.1.1"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.7.5"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
