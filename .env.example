# ─────────────────────────────────────────────
# ElectroTrack POS — Environment Variables
# Copy this file to .env and fill in all values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────

# ── Server ────────────────────────────────────
PORT="3000"
NODE_ENV="development"                          # development | production
FRONTEND_URL="http://localhost:5173"            # Vercel URL in production

# ── Database (Supabase PostgreSQL) ────────────
# Get from: Supabase → Project Settings → Database → Connection String → Session pooler
DATABASE_URL="postgresql://postgres.mlxopjdfjbdmiovnhugp:Office%231234_h@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres"
# Get from: Supabase → Project Settings → Database → Connection String → URI (Direct Connection, port 5432)
DIRECT_URL="postgresql://postgres.mlxopjdfjbdmiovnhugp:Office%231234_h@db.mlxopjdfjbdmiovnhugp.supabase.co:5432/postgres"

# ── Redis (Upstash) ───────────────────────────
# REDIS_URL="rediss://:<password>@<host>.upstash.io:6379"

# ── JWT ───────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# JWT_SECRET="replace_with_64_char_random_hex"
# JWT_REFRESH_SECRET="replace_with_different_64_char_random_hex"
# JWT_ACCESS_EXPIRES_IN="15m"
# JWT_REFRESH_EXPIRES_IN="7d"
# JWT_OTP_EXPIRES_IN="2m"                         # Short-lived token after OTP verify

# ── OTP ───────────────────────────────────────
OTP_TTL_SECONDS="300"                           # 5 minutes
OTP_LENGTH="6"

# ── SMTP (for OTP emails) ─────────────────────
# Option A: Gmail SMTP (dev / small scale)
SMTP_HOST="smtp.resend.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="resend"
SMTP_PASS="re_your_resend_api_key_here"
SMTP_FROM="ElectroTrack <noreply@yourdomain.com>"

# Option B: Gmail (dev only — use App Password)
# SMTP_HOST="smtp.gmail.com"
# SMTP_USER="your@gmail.com"
# SMTP_PASS="your_gmail_app_password"

# ── File Storage (Cloudflare R2 / S3-compatible) ─────────────────────────────
# R2_ACCOUNT_ID="your_cloudflare_account_id"
# R2_ACCESS_KEY_ID="your_r2_access_key_id"
# R2_SECRET_ACCESS_KEY="your_r2_secret_access_key"
# R2_BUCKET_NAME="electrotrack-invoices"
# R2_PUBLIC_URL="https://pub-xxx.r2.dev"

# ── Supabase (if using Supabase SDK directly) ─────────────────────────────────
# SUPABASE_URL="https://[project-ref].supabase.co"
# SUPABASE_ANON_KEY="eyJ..."       # Safe to expose in frontend
# SUPABASE_SERVICE_KEY="eyJ..."    # Backend only — NEVER expose to frontend

# ── App Config ────────────────────────────────
SHOP_NAME="My Electronics Shop"
DEFAULT_LOW_STOCK_THRESHOLD="2"                 # Alert when units drop below this
DEAD_STOCK_DAYS="60"                            # Flag units unsold longer than N days
MAX_DISCOUNT_WITHOUT_OTP="500"                  # Rs. cashier can discount below this freely
RETURN_FRAUD_WINDOW_DAYS="30"                   # Flag if same customer returns N+ times in this window
RETURN_FRAUD_COUNT_THRESHOLD="2"

# ── Rate Limiting ─────────────────────────────
RATE_LIMIT_GLOBAL="100"                         # requests/minute per IP
RATE_LIMIT_AUTH="10"                            # stricter for /auth/* routes
RATE_LIMIT_UPLOAD="5"                           # for bulk CSV import

# ── CORS ──────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash)
ALLOWED_ORIGINS="http://localhost:5173,https://your-app.vercel.app"

# ── Bcrypt ────────────────────────────────────
BCRYPT_ROUNDS="12"
